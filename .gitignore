# ── Data files (not for version control) ─────────────────────────────────────
# LARGE DATASETS - Keep locally or in cloud storage, do NOT commit
# - Yelp-JSON/yelp.duckdb (1-2 GB)
# + See DEPLOYMENT.md for cloud storage strategy

# Development/Local data
Yelp-JSON/
Yelp/
data/preprocessed_yelp/
data/processed_yelp_easystudy/*.duckdb

# DO COMMIT: Training mappings (small, deterministic, required for inference)
!data/processed_yelp_easystudy/item2index.pkl
!data/processed_yelp_easystudy/user2index.pkl
!data/processed_yelp_easystudy/business2index.pkl

# BUT: DO COMMIT test_data/ with sample datasets for CI/testing
!test_data/
test_data/**/.gitkeep

# Ignore most output files (training artifacts, plots, metrics)
# EXCEPT: commit the latest model checkpoint for Streamlit Cloud
outputs/*
outputs/**/*
!outputs/20260409_132816
!outputs/20260409_132816/**
!outputs/LATEST_RUN.txt
!outputs/neuron_category_metadata.json

# JSON files (except those in outputs/)
*.json
!outputs/**/*.json

*.jsonl
*.png
!outputs/**/*.png
*.npz
*.duckdb
notebooks/*.duckdb

