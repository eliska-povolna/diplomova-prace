# Cloud SQL Configuration for Streamlit UI
# Copy this to .env and fill in your Cloud SQL credentials

# =============================================================================
# CLOUD SQL BACKEND (Optional - leave blank for local DuckDB)
# =============================================================================

# Cloud SQL instance connection string: project:region:instance-name
# Example: my-project:europe-central2:diplomova-prace-db
CLOUDSQL_INSTANCE=

# Cloud SQL database name (typically "postgres")
CLOUDSQL_DATABASE=postgres

# Cloud SQL user (typically "postgres")
CLOUDSQL_USER=postgres

# Cloud SQL password (set in Cloud Console)
CLOUDSQL_PASSWORD=

# =============================================================================
# OPTIONAL: Cloud Storage & Cloud SQL Backend
# =============================================================================

# The unified DataService automatically detects and uses Cloud SQL if
# credentials are provided, otherwise falls back to local DuckDB.

# Set to "true" to enable Cloud SQL backend (requires CLOUDSQL_* vars below)
USE_CLOUD_STORAGE=false

# Google Cloud Storage bucket name (for metadata/exports)
GCS_BUCKET_NAME=

# Google Cloud Project ID (optional, auto-detected from credentials)
GCP_PROJECT_ID=

# Service account JSON path (optional, uses default credentials if not set)
GOOGLE_CREDENTIALS_PATH=

# =============================================================================
# LOCAL BACKEND (Default)
# =============================================================================
# These are used when Cloud SQL is not configured or connection fails

# Already configured in src/ui/config/config.yaml - no env vars needed
# Falls back to:
# - data/yelp.duckdb
# - data/yelp_parquet/

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# 
# 1. LOCAL DEVELOPMENT (default):
#    - Leave all CLOUDSQL_* variables blank
#    - App uses local DuckDB + Parquet files
#    - Works offline
#
# 2. GOOGLE CLOUD RUN:
#    - Set CLOUDSQL_INSTANCE in .env or Cloud Run secrets
#    - App automatically detects and uses Cloud SQL
#    - Falls back to local if Cloud SQL fails
#
# 3. DOCKER DEPLOYMENT:
#    - Mount .env file: docker run --env-file .env
#    - Or pass individual variables: docker run -e CLOUDSQL_INSTANCE=...
#
# =============================================================================
