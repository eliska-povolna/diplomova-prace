# Streamlit Secrets Configuration Template
# 
# For local development:
#   1. Copy this file to .streamlit/secrets.toml
#   2. Fill in your credentials below
#   3. Streamlit will automatically load secrets from this file
#
# For Streamlit Cloud:
#   1. Go to your repository Settings > Secrets
#   2. Add each key-value pair below as a GitHub Secret
#   3. Streamlit Cloud automatically maps them to st.secrets
#
# IMPORTANT: .streamlit/secrets.toml should NEVER be committed to git
# See .gitignore - it's already excluded

# =============================================================================
# CLOUD SQL CONFIGURATION (Optional - leave blank for local DuckDB)
# =============================================================================

# Cloud SQL instance connection string: project:region:instance-name
CLOUDSQL_INSTANCE = ""

# Cloud SQL user
CLOUDSQL_USER = "postgres"

# Cloud SQL password
CLOUDSQL_PASSWORD = ""

# Cloud SQL database
CLOUDSQL_DATABASE = "postgres"

# Cloud SQL host (optional, usually auto-discovered from CLOUDSQL_INSTANCE)
CLOUDSQL_HOST = ""

# =============================================================================
# GOOGLE CLOUD & AI APIs (Optional)
# =============================================================================

# Google API key for Generative AI (neuron labeling)
GOOGLE_API_KEY = ""

# Google Cloud Project ID
GOOGLE_CLOUD_PROJECT = ""

# Google Cloud region
GOOGLE_CLOUD_REGION = "us-central1"

# Google Cloud Storage bucket name (for metadata export)
GCS_BUCKET_NAME = ""

# GCS metadata folder prefix
GCS_METADATA_PREFIX = "metadata/"

# GCS model data folder prefix
GCS_MODELDATA_PREFIX = "models/"

# =============================================================================
# GOOGLE SERVICE ACCOUNT CREDENTIALS (Optional - for GCS/Cloud SQL)
# =============================================================================
# 
# If you have a Google Cloud service account JSON file, add its contents here.
# This allows the app to authenticate with GCS and Cloud SQL on deployment.
# 
# To get a service account key:
#   1. Go to Google Cloud Console > Service Accounts
#   2. Create or select a service account
#   3. Create a JSON key
#   4. Copy the entire JSON content below
#

[google_credentials]
# type = "service_account"
# project_id = "your-project-id"
# private_key_id = "key-id"
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "service-account@your-project.iam.gserviceaccount.com"
# client_id = "123456789"
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/..."
